# ---- Core ----
NODE_ENV=development
PORT=3001
API_PREFIX=api
# In production CORS_ORIGINS must be an explicit, non-wildcard allowlist
# (credentials are enabled), e.g. https://yourdomain.com
CORS_ORIGINS=*
# Number of proxy hops to trust (behind the Nginx gateway = 1)
TRUST_PROXY_HOPS=1
SWAGGER_ENABLED=true
LOG_LEVEL=info

# ---- Database ----
# Production: your self-hosted Postgres. Dev on Replit: built from SUPABASE_DB_URL
# via scripts/db-url.mjs (npm run prisma:pull / start scripts handle this).
DATABASE_URL=postgresql://user:password@localhost:5432/dynime

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=30d

# ---- Rate limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ---- Redis (cache + BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Object storage (MinIO / S3) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://localhost:9000

# ---- Supabase (migration source only; remove after cutover) ----
# SUPABASE_DB_URL and SUPABASE_SERVICE_ROLE_KEY are provided as Replit secrets.
