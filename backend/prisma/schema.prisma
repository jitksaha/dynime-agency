  utm_campaign       String?  @db.VarChar(100)
  cookie_id          String?  @unique @db.VarChar(255)
  converted          Boolean  @default(false)
  order_id           String?  @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  last_visit         DateTime @default(now()) @db.Timestamptz(6)
  partners           partners @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model commissions {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id        String    @db.Uuid
  order_id          String    @db.Uuid
  customer_id       String?   @db.Uuid
  service_name      String    @db.VarChar(255)
  order_amount      Decimal   @db.Decimal(10, 2)
  profit_amount     Decimal   @db.Decimal(10, 2)
  commission_amount Decimal   @db.Decimal(10, 2)
  status            String    @default("pending") @db.VarChar(50)
  approved_at       DateTime? @db.Timestamptz(6)
  paid_at           DateTime? @db.Timestamptz(6)
  payout_id         String?   @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  commission_type   String    @default("standard") @db.VarChar(50)
  cost_amount       Decimal?  @default(0.00) @db.Decimal(10, 2)
  partners          partners  @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payouts           payouts?  @relation(fields: [payout_id], references: [id], onUpdate: NoAction)

  @@schema("public")
}

model payouts {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id     String        @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  payout_method  String        @db.VarChar(100)
  details        Json          @default("{}")
  status         String        @default("pending") @db.VarChar(50)
  transaction_id String?       @db.VarChar(255)
  paid_at        DateTime?     @db.Timestamptz(6)
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  updated_at     DateTime      @default(now()) @db.Timestamptz(6)
  commissions    commissions[]
  partners       partners      @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model commission_rules {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  min_amount Decimal  @db.Decimal(10, 2)
  max_amount Decimal  @db.Decimal(10, 2)
  commission Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

