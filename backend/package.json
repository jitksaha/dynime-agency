    "mammoth": "^1.12.0",
    "minio": "^8.0.1",
    "nest-winston": "^1.10.0",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
