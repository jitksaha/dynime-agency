{
  "name": "dynime-backend",
  "version": "0.1.0",
  "description": "Dynime NestJS backend (Supabase migration target)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:url": "node scripts/db-url.mjs",
    "prisma:pull": "DATABASE_URL=\"$(node scripts/db-url.mjs)\" prisma db pull",
