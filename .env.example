# ── Required ─────────────────────────────────────────────────────────────────
SUPABASE_DB_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=eyJ...

JWT_ACCESS_SECRET=change-me-32-chars-minimum
JWT_REFRESH_SECRET=change-me-32-chars-minimum

# ── MinIO (object storage) ─────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Didit (KYC/KYB/AML) — optional ──────────────────────────────────────────
DIDIT_API_KEY=
DIDIT_KYC_WORKFLOW_ID=
DIDIT_KYB_WORKFLOW_ID=
DIDIT_AML_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
POSTGRES_PASSWORD=change-me   # only if self-hosting PostgreSQL (see docker-compose.yml)
