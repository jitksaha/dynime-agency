# React SPA .htaccess — Hostinger LiteSpeed + Apache compatible
# Handles client-side routing for React Router (fixes intermittent 404 on SPA routes)

# Explicitly set document root index
DirectoryIndex index.html index.php

# ─── LiteSpeed SPA Fallback ───────────────────────────────────────────────────
# FallbackResource is processed BEFORE mod_rewrite on LiteSpeed.
# This is the primary fix for "404 Not Found" on SPA routes (/invoice, /careers, etc.)
# It tells LiteSpeed: if the requested path doesn't exist as a file/dir, serve index.html
FallbackResource /index.html

# ─── Error Document ───────────────────────────────────────────────────────────
# Catches any 404 that LiteSpeed generates before mod_rewrite fires.
# Works as a second safety net alongside FallbackResource.
ErrorDocument 404 /index.html

# ─── Rewrite Rules ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block cPanel's default page redirect
    RewriteRule ^cgi-sys/defaultwebpage\.cgi$ /index.html [R=301,L]

    # ── API passthrough — MUST be before SPA catch-all ──────────────────────
    # Laravel API requests must reach PHP, not be served index.html
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^ - [L]

    # ── PHP scripts — execute directly ──────────────────────────────────────
    RewriteCond %{REQUEST_URI} \.php$ [NC]
    RewriteRule ^ - [L]

    # ── SPA catch-all — serve index.html for all non-file/dir routes ─────────
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ /index.html [L]
</IfModule>

# ─── Cache Headers ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ─── Gzip Compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ─── Security & Cache Headers ─────────────────────────────────────────────────
<IfModule mod_headers.c>
    # HTML entry point — never cache (ensures users always get latest SPA shell)
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
        # Disable LiteSpeed caching for the SPA entry point
        Header set X-LiteSpeed-Cache-Control "no-cache"
    </FilesMatch>

    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Immutable cache for Vite content-hashed assets
    <FilesMatch "\.[0-9a-f]{8}\.(js|css|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ─── Block Sensitive Files ─────────────────────────────────────────────────────
<FilesMatch "(^#.*#|\.(bak|config|dist|fla|inc|ini|log|psd|sh|sql|sw[op])|~)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

