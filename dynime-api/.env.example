APP_NAME="Dynime API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dynime.com/api
FRONTEND_URL=https://dynime.com

# Database (MySQL on shared hosting)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dynime_db
DB_USERNAME=dynime_user
DB_PASSWORD=

# Cache & Session (file-based — no Redis required)
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# Queue (database — no Redis required)
QUEUE_CONNECTION=database

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=hello@dynime.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@dynime.com
MAIL_FROM_NAME="Dynime"

# Storage
FILESYSTEM_DISK=public
MAX_UPLOAD_SIZE=10240

# Admin (used by seeder)
ADMIN_EMAIL=admin@dynime.com
ADMIN_PASSWORD=change-this-password-now

# Google Drive Backup (optional)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# Rate Limiting
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_ADMIN=300

# Sanctum
SANCTUM_STATEFUL_DOMAINS=dynime.com,localhost:5173
